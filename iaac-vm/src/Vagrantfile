# -*- mode: ruby -*-
# vi: set ft=ruby :

# Домашнее задание «Применение принципов IaaC в работе с виртуальными машинами»
# Задача 2: создание ВМ VirtualBox через Vagrant с предустановленным Docker.
#
# Примечание: образ bento/ubuntu-20.04 из задания отдаёт 404 на Vagrant Cloud,
# поэтому используется рекомендованное в задании зеркало bento/ubuntu-24.04.

Vagrant.configure("2") do |config|
  # Базовый образ (box). bento/* — официальные образы проекта Chef Bento.
  config.vm.box = "bento/ubuntu-24.04"

  # Имя ВМ в интерфейсе VirtualBox + параметры ресурсов.
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "iaac-docker-vm"
    vb.memory = 2048
    vb.cpus   = 2
  end

  # Hostname внутри гостевой системы.
  config.vm.hostname = "iaac-docker-vm"

  # Приватная сеть host-only для доступа к ВМ с хоста.
  config.vm.network "private_network", ip: "192.168.56.10"

  # Provisioning: ставим Docker по официальной инструкции для Debian/Ubuntu
  # (apt-репозиторий Docker). Скрипт вынесен в отдельный файл для читаемости.
  config.vm.provision "shell", path: "scripts/install_docker.sh"

  # Сообщение после поднятия ВМ.
  config.vm.post_up_message = <<-MSG
    ВМ поднята. Проверка Docker внутри ВМ:
      vagrant ssh
      docker version && docker compose version
  MSG
end
